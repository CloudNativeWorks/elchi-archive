#!/usr/bin/env bash
# elchi-stack — operator helper. Installed at /usr/local/bin/elchi-stack
# during install. Provides cluster-wide control: status, logs,
# reload-envoy, add-node, init-replica-set, export-bundle.

set -Eeuo pipefail

ELCHI_INSTALLER_ROOT=${ELCHI_INSTALLER_ROOT:-/opt/elchi-installer}

# Source the same lib/ tree the installer used. This is shipped during
# install (orchestrator copies the installer to /opt/elchi-installer on
# every node).
if [ -d "${ELCHI_INSTALLER_ROOT}/lib" ]; then
  # shellcheck source=lib/common.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/common.sh"
  # shellcheck source=lib/topology.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/topology.sh"
  # shellcheck source=lib/ssh.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/ssh.sh"
  # shellcheck source=lib/envoy.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/envoy.sh"
  # shellcheck source=lib/mongodb.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/mongodb.sh"
  # shellcheck source=lib/secrets.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/secrets.sh"
  # shellcheck source=lib/bundle.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/bundle.sh"
  # shellcheck source=lib/dirs.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/dirs.sh"
  # shellcheck source=lib/backend.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/backend.sh"
  # shellcheck source=lib/grafana.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/grafana.sh"
  # shellcheck source=lib/systemd.sh
  . "${ELCHI_INSTALLER_ROOT}/lib/systemd.sh"
else
  printf 'elchi-stack: installer libs missing (looked under %s)\n' "$ELCHI_INSTALLER_ROOT" >&2
  exit 1
fi

# _ssh_setup — pull persisted SSH creds from /etc/elchi/orchestrator.env
# (USER/PORT/KEY) into env vars, then call ssh::configure so subsequent
# ssh::run / ssh::scp use the cluster key non-interactively. Every
# subcommand that touches a remote host MUST call this first; otherwise
# ssh falls back to the default identity → password prompt.
_ssh_setup() {
  ssh::load_persisted_creds
  ssh::configure "${ELCHI_SSH_USER:-root}" "${ELCHI_SSH_PORT:-22}" "${ELCHI_SSH_KEY:-}" ""
}

usage() {
  cat <<EOF
elchi-stack — operator helper

Usage:
  elchi-stack status                  cluster-wide service summary
  elchi-stack logs <unit> [-f]        tail journalctl on every node
  elchi-stack reload-envoy            re-render bootstrap and restart Envoy on every node
  elchi-stack add-node <ip>           extend the cluster (M1 only)
  elchi-stack init-replica-set        rs.initiate() (M1 only; idempotent)
  elchi-stack mongo-status            replica-set health snapshot (M1 only)
                                       — primary, per-member state / health /
                                       uptime / replication lag / heartbeat msg
  elchi-stack export-bundle <out> [--reuse-bundle-key]
                                      repackage the encrypted cluster bundle.
                                       --reuse-bundle-key uses the install-time
                                       key persisted at /etc/elchi/.bundle-key
                                       so an exported bundle can be reapplied
                                       to the existing cluster without
                                       redistributing a fresh decryption key.
  elchi-stack show-secret <name>      print a stored credential
                                       (grafana | jwt | gslb | mongo-app | mongo-root | all)
  elchi-stack rotate-secret <name>    rotate JWT/GSLB/Grafana secret (cluster-wide restart for jwt/gslb)
  elchi-stack verify                  end-to-end cluster health check
                                       (registration logs, Envoy admin, listener ports)

EOF
}

cmd_status() {
  if [ ! -f /etc/elchi/nodes.list ]; then
    printf 'no /etc/elchi/nodes.list — is this M1?\n' >&2
    exit 1
  fi
  _ssh_setup

  # Status query: every "elchi-*" unit (templates included via the @* glob)
  # PLUS the externally-managed services we drive (mongod, grafana-server,
  # nginx). Without listing those, M1 looks like it's missing mongo/VM/UI
  # because those packages don't carry an "elchi-" prefix even though
  # elchi-stack owns their config + lifecycle on this host. The glob is
  # passed through bash -c on the remote side so the shell on the local
  # box doesn't try to expand 'elchi-*' against /etc.
  local query=$(cat <<'EOF'
systemctl list-units --no-pager --no-legend --type=service \
  'elchi-*' 'elchi-control-plane-*@*' \
  mongod.service grafana-server.service nginx.service 2>/dev/null
EOF
)
  local host
  while IFS= read -r host; do
    [ -z "$host" ] && continue
    printf '\n%s── %s ──%s\n' "$C_BOLD" "$host" "$C_RESET"
    if ssh::is_local "$host"; then
      bash -c "$query" | awk '{printf "  %-50s %s\n", $1, $4}'
    else
      ssh::run "$host" bash -c "$query" | awk '{printf "  %-50s %s\n", $1, $4}'
    fi
  done < /etc/elchi/nodes.list
}

cmd_logs() {
  local unit=${1:-}
  shift || true
  [ -n "$unit" ] || { printf 'unit name required\n' >&2; exit 2; }
  local follow=0
  case "${1:-}" in
    -f|--follow) follow=1 ;;
  esac

  _ssh_setup

  if [ "$follow" = "1" ]; then
    # Multi-host live tail: each node's `journalctl -f` runs in the
    # background and writes to a shared stdout. Two issues to handle:
    #
    #   (a) Interleaving — without per-line prefixing, a line from node A
    #       can land under node B's banner and look like it came from B.
    #       Pipe each stream through `sed` to prepend "[host] ".
    #
    #   (b) Ctrl+C — `wait` returns 130 on SIGINT, and `set -Eeuo
    #       pipefail` then triggers the global ERR handler ("[ERR]
    #       installer exited with rc=130"). Trap INT/TERM so the user
    #       can break out of `-f` cleanly: kill the children, exit 0.
    local pids=() host
    # shellcheck disable=SC2064
    trap 'kill ${pids[*]:-} 2>/dev/null || true; exit 0' INT TERM
    while IFS= read -r host; do
      [ -z "$host" ] && continue
      if ssh::is_local "$host"; then
        ( journalctl -u "$unit" -f --no-pager 2>&1 \
            | sed -u "s/^/[$host] /" ) &
      else
        ( ssh::run "$host" bash -c "journalctl -u '$unit' -f --no-pager" 2>&1 \
            | sed -u "s/^/[$host] /" ) &
      fi
      pids+=("$!")
    done < /etc/elchi/nodes.list
    wait
    return 0
  fi

  # Non-follow mode: serial dump per host with a banner — no interleave
  # risk, no SIGINT loop to manage.
  local host
  while IFS= read -r host; do
    [ -z "$host" ] && continue
    printf '\n%s── %s : %s ──%s\n' "$C_BOLD" "$host" "$unit" "$C_RESET"
    if ssh::is_local "$host"; then
      journalctl -u "$unit" -n 50 --no-pager
    else
      ssh::run "$host" bash -c "journalctl -u '$unit' -n 50 --no-pager"
    fi
  done < /etc/elchi/nodes.list
}

cmd_reload_envoy() {
  _ssh_setup
  local host
  while IFS= read -r host; do
    [ -z "$host" ] && continue
    log::node "$host" "re-rendering envoy.yaml + restarting"
    if ssh::is_local "$host"; then
      envoy::reload
    else
      # Render new bootstrap locally (state is identical cluster-wide
      # since it derives from /etc/elchi/topology.full.yaml + ports.full.json),
      # then push to the remote and restart over there.
      envoy::render_bootstrap
      # ssh::scp now streams via `sudo install /dev/stdin` so we can
      # write directly to the final destination with no /tmp dance.
      # Fix up ownership (install lands it root:root) and restart.
      ssh::scp /etc/elchi/config/envoy.yaml "$host" /etc/elchi/config/envoy.yaml
      ssh::run_sudo "$host" "chown root:elchi /etc/elchi/config/envoy.yaml && chmod 0640 /etc/elchi/config/envoy.yaml && systemctl restart elchi-envoy.service"
    fi
  done < /etc/elchi/nodes.list
  log::ok "envoy reloaded cluster-wide"
}

cmd_add_node() {
  local new_ip=""
  local skip_confirm=0
  # Two-pass arg loop: pull --yes-i-mean-it / -y out for the prompt,
  # let everything else (e.g. --ssh-key, --ssh-port) pass through to
  # install.sh below. Keeps the flag surface compatible with operator
  # muscle memory from `bash get.sh --uninstall --yes-i-mean-it`.
  local -a passthru=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --yes-i-mean-it|-y) skip_confirm=1 ;;
      -h|--help)
        printf 'Usage: elchi-stack add-node <ip> [--yes-i-mean-it] [extra flags forwarded to install.sh]\n'
        return 0
        ;;
      -*) passthru+=("$1") ;;
      *)
        if [ -z "$new_ip" ]; then new_ip=$1
        else passthru+=("$1")
        fi
        ;;
    esac
    shift
  done
  [ -n "$new_ip" ] || die "new node IP required: elchi-stack add-node <ip>"

  if [ ! -f /etc/elchi/nodes.list ] || [ ! -f /etc/elchi/topology.full.yaml ]; then
    die "no /etc/elchi/nodes.list or topology.full.yaml — run install.sh first"
  fi

  # Existing topology: nodes + persisted install-time choices. We
  # forward all of these to install.sh on rerun so the operator
  # doesn't have to re-type --main-address / --backend-version /
  # --gslb-zone / --ui-version / --envoy-version. install.sh would
  # otherwise hard-fail on the missing --main-address.
  local existing_csv existing_count new_pos
  existing_csv=$(paste -sd, /etc/elchi/nodes.list)
  existing_count=$(wc -l < /etc/elchi/nodes.list | tr -d ' ')
  new_pos=$(( existing_count + 1 ))

  if grep -qxF "$new_ip" /etc/elchi/nodes.list 2>/dev/null; then
    die "${new_ip} is already in /etc/elchi/nodes.list — refusing to add a duplicate"
  fi

  local merged="${existing_csv},${new_ip}"

  local main_addr port install_gslb gslb_zone gslb_admin gslb_nameservers gslb_regions
  main_addr=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+main_address:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  port=$(awk      '/^cluster:/{f=1; next} f && /^[[:space:]]+port:/{print $2; exit}'         /etc/elchi/topology.full.yaml)
  install_gslb=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+install_gslb:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  gslb_zone=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+gslb_zone:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  gslb_admin=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+gslb_admin_email:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  # Nameservers + regions are operator-supplied at install time and must
  # round-trip through topology.full.yaml so add-node's install.sh rerun
  # doesn't re-render Corefile / zone.db without them.
  gslb_nameservers=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+gslb_nameservers:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  gslb_regions=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+gslb_regions:/{print $2; exit}' /etc/elchi/topology.full.yaml)
  [ -n "$main_addr" ] || die "main_address missing from topology.full.yaml — file may be corrupt"

  local ui_version envoy_version coredns_version
  ui_version=$(awk      '/^versions:/{f=1; next} f && /^  ui:/{print $2; exit}'      /etc/elchi/topology.full.yaml)
  envoy_version=$(awk   '/^versions:/{f=1; next} f && /^  envoy:/{print $2; exit}'   /etc/elchi/topology.full.yaml)
  coredns_version=$(awk '/^versions:/{f=1; next} f && /^  coredns:/{print $2; exit}' /etc/elchi/topology.full.yaml)

  # backend_variants is a multi-line list under `versions:` — collect
  # to CSV in document order so install.sh + the cluster keep their
  # existing port allocations.
  local variants_csv
  variants_csv=$(awk '
    /^  backend_variants:/ { f=1; next }
    f && /^    -[[:space:]]+/ { sub(/^    -[[:space:]]+/, "", $0); printf "%s%s", sep, $0; sep="," }
    f && /^[a-zA-Z]/ { exit }
  ' /etc/elchi/topology.full.yaml)
  [ -n "$variants_csv" ] || die "backend_variants missing from topology.full.yaml"

  # ---- mongo impact (drives the preview banner + operator warnings) -----
  # Mirrors lib/topology.sh::is_mongo_node:
  #   N=1|2  → only idx=1 runs mongo (standalone)
  #   N>=3   → idx 1..3 run mongo (replica set)
  # The interesting transition is N=2 → N=3: M1 flips standalone→RS,
  # M2 gets a fresh mongod install for the first time, M3 same. That's
  # the only shape that imposes a brief write-availability gap.
  local mongo_impact_label mongo_impact_lines
  if [ "$existing_count" = "1" ] && [ "$new_pos" = "2" ]; then
    mongo_impact_label="no migration"
    mongo_impact_lines="this node will NOT run mongo (will reach M1's standalone mongod over LAN)"
  elif [ "$existing_count" = "2" ] && [ "$new_pos" = "3" ]; then
    # Bash 3.2 (macOS dev shell) has parser bugs with heredocs nested
    # inside $(...) when the body contains parens / apostrophes — build
    # this multi-line message with explicit \n joins instead of cat<<EOF
    # so the script lints cleanly across every shell version.
    mongo_impact_label="${C_YELLOW}STANDALONE -> REPLICA SET migration${C_RESET}"
    mongo_impact_lines="M1 mongod will be reconfigured (replSetName=elchi-rs) and restarted
M2 + M3 will install mongo for the first time (apt-get mongodb-org)
rs.initiate() will run with all 3 members
expected write-availability gap: ~10-30s during M1 restart
existing M1 data is preserved and replicated to M2/M3 on initial sync"
  elif [ "$new_pos" -le 3 ] 2>/dev/null; then
    mongo_impact_label="this node joins the RS"
    mongo_impact_lines="mongod will be installed and added to the elchi-rs replica set"
  else
    mongo_impact_label="no mongo (capped at 3 RS members)"
    mongo_impact_lines="mongo stays on M1+M2+M3; this node connects via the cluster URI like every other backend service"
  fi

  # ---- preview banner ---------------------------------------------------
  printf '\n%b==> Add-node preview%b\n\n' "$C_BOLD" "$C_RESET"
  printf '  current cluster:  %d node(s) — %s\n' "$existing_count" "$existing_csv"
  printf '  new node:         %s (will be M%d)\n' "$new_ip" "$new_pos"
  printf '  cluster size:     %d → %d\n\n' "$existing_count" "$new_pos"

  printf '  what will happen:\n'
  printf '    [admin user]    create elchi-cluster-admin on %s (cluster key authorized)\n' "$new_ip"
  printf '    [bootstrap]     ssh-copy-id cluster key (interactive password if needed)\n'
  printf '    [mongo]         %b\n' "$mongo_impact_label"
  while IFS= read -r _line; do
    [ -n "$_line" ] && printf '                    %s\n' "$_line"
  done <<<"$mongo_impact_lines"
  printf '    [new node]      install backend (controller + control-plane), envoy, nginx, coredns, otel\n'
  printf '    [topology]      re-render topology.full.yaml + ports.full.json\n'
  printf '    [tls]           regenerate self-signed cert (SAN list will include %s)\n' "$new_ip"
  printf '    [/etc/hosts]    push the new managed block to every node\n'
  if [ "$install_gslb" = "1" ]; then
    printf '    [coredns]       new CoreDNS instance binds %s:53 with the same Corefile\n' "$new_ip"
    if [ -n "$gslb_nameservers" ]; then
      printf '                    NS records preserved from topology (--gslb-nameservers=%s);\n' "$gslb_nameservers"
      printf '                    operator-supplied list is NOT auto-extended -- pass a new\n'
      printf '                    --gslb-nameservers=... if you want %s to advertise as NS\n' "$new_ip"
    else
      # auto-derive default kicks in: every cluster node becomes an ns<idx>
      printf '                    no operator NS list -- defaults to one ns<idx> entry per\n'
      printf '                    cluster node; %s will be added as ns%d:%s automatically\n' \
        "$new_ip" "$new_pos" "$new_ip"
    fi
  fi
  printf '    [existing M*]   envoy.yaml + backend common.env get re-rendered with the\n'
  printf '                    new peer set; fingerprint reconcile restarts envoy and the\n'
  printf '                    affected backends on each existing node (~1-3s gap per\n'
  printf '                    node, sequential -- front-door HTTPS may briefly 5xx)\n\n'
  printf '  estimated time:   3-5 min\n\n'

  # ---- confirm ----------------------------------------------------------
  if [ "$skip_confirm" != "1" ]; then
    if [ ! -t 0 ]; then
      die "no controlling tty; pass --yes-i-mean-it for non-interactive add-node"
    fi
    local ans
    read -r -p "About to add ${new_ip} to the cluster (size ${existing_count} → ${new_pos}). Type 'yes' to continue: " ans
    [ "$ans" = "yes" ] || die "aborted"
  fi

  # ---- compose + exec install.sh re-run ---------------------------------
  local -a cmd=(
    bash "${ELCHI_INSTALLER_ROOT}/install.sh"
    --nodes="$merged"
    --main-address="$main_addr"
    --backend-version="$variants_csv"
    --non-interactive
  )
  [ -n "$port" ]            && cmd+=(--port="$port")
  [ -n "$ui_version" ]      && cmd+=(--ui-version="$ui_version")
  [ -n "$envoy_version" ]   && cmd+=(--envoy-version="$envoy_version")
  [ -n "$coredns_version" ] && cmd+=(--coredns-version="$coredns_version")
  [ "$install_gslb" = "1" ] && cmd+=(--gslb)
  [ -n "$gslb_zone" ]       && cmd+=(--gslb-zone="$gslb_zone")
  [ -n "$gslb_admin" ]      && cmd+=(--gslb-admin-email="$gslb_admin")
  [ -n "$gslb_nameservers" ] && cmd+=(--gslb-nameservers="$gslb_nameservers")
  [ -n "$gslb_regions" ]     && cmd+=(--gslb-regions="$gslb_regions")
  [ -n "${ELCHI_SSH_USER:-}" ] && cmd+=(--ssh-user="$ELCHI_SSH_USER")
  [ -n "${ELCHI_SSH_KEY:-}" ]  && cmd+=(--ssh-key="$ELCHI_SSH_KEY")
  [ -n "${ELCHI_SSH_PORT:-}" ] && cmd+=(--ssh-port="$ELCHI_SSH_PORT")

  log::info "extending cluster: ${existing_csv} → ${merged}"
  exec "${cmd[@]}" "${passthru[@]}"
}

cmd_init_rs() {
  mongodb::initiate_replica_set
}

# cmd_mongo_status — print mongo replica-set health from M1's perspective.
# Single-shot rs.status() snapshot: PRIMARY identification, per-member
# state / health / uptime / replication lag / lastHeartbeatMessage.
#
# M1-only: the only node where /etc/elchi/mongo/root.env exists (mongo
# root creds — never shipped to M2/M3 in the bundle). Cross-node read
# would require either persisting root creds elsewhere or proxying via
# SSH; both add attack surface for a tool that's purely diagnostic.
# Operators on M2/M3 get a clean error pointing at M1 instead.
cmd_mongo_status() {
  if [ ! -f /etc/elchi/mongo/root.env ]; then
    local m1_ip=""
    [ -f /etc/elchi/nodes.list ] && m1_ip=$(head -1 /etc/elchi/nodes.list)
    printf 'mongo-status is M1-only — run on M1%s\n' \
      "${m1_ip:+ ($m1_ip)}" >&2
    exit 1
  fi

  local size=1
  if [ -f /etc/elchi/topology.full.yaml ]; then
    size=$(awk '/^cluster:/{f=1; next} f && /^[[:space:]]+size:/{print $2; exit}' \
             /etc/elchi/topology.full.yaml)
  fi

  # Standalone shortcut. cluster_size < 3 means this install never
  # configured a replica set (lib/topology.sh::is_mongo_node caps RS
  # at 3 members and uses standalone for size 1-2). rs.status() would
  # error here with NotYetInitialized, so just report the basic
  # mongod liveness instead of a misleading "RS down".
  if [ "${size:-1}" -lt 3 ] 2>/dev/null; then
    printf '%bStandalone mongo%b (cluster size=%s, no replica set)\n' \
      "$C_BOLD" "$C_RESET" "$size"
    if systemctl is-active --quiet mongod 2>/dev/null; then
      log::ok "mongod active on 127.0.0.1:27017"
    else
      log::err "mongod NOT active"
      exit 1
    fi
    return 0
  fi

  # RS path. Emit one tagged line per member from inside mongosh —
  # each line survives the `  [mongosh] ` prefix wrapping that
  # `mongodb::eval_root` adds (lib/mongodb.sh:262), so we parse with
  # `sed -n 's/.*MEMBER|/MEMBER|/p'` rather than line-anchored grep.
  # The pipe (`|`) is the field separator since hostnames can contain
  # ':' and lastHeartbeatMessage can contain spaces / commas.
  local out
  out=$(mongodb::eval_root "
    var s = rs.status();
    print('SUMMARY|' + s.set + '|' + (s.term || 0) + '|' + s.ok);
    var primaryOptime = null;
    s.members.forEach(function(m) {
      if (m.stateStr === 'PRIMARY' && m.optimeDate) primaryOptime = m.optimeDate;
    });
    s.members.forEach(function(m) {
      var lag = '-';
      if (m.optimeDate && primaryOptime) {
        lag = (primaryOptime - m.optimeDate) + 'ms';
      }
      var hb = m.lastHeartbeatMessage || '';
      print('MEMBER|' + m._id + '|' + m.name + '|' + m.stateStr +
            '|' + m.health + '|' + (m.uptime || 0) + '|' + lag +
            '|' + hb);
    });
    print('EVAL_OK');
  " 2>/dev/null) || die "rs.status() failed - is mongod running on M1? (check 'systemctl status mongod')"

  local set_name term ok
  read -r set_name term ok < <(
    printf '%s\n' "$out" \
      | sed -n 's/.*SUMMARY|\([^|]*\)|\([^|]*\)|\([^|]*\).*/\1 \2 \3/p' \
      | head -1
  )

  printf '\n%bReplica set:%b %s (term=%s, ok=%s)\n\n' \
    "$C_BOLD" "$C_RESET" "${set_name:-?}" "${term:-?}" "${ok:-?}"

  local id name state health uptime lag hb marker color
  while IFS='|' read -r id name state health uptime lag hb; do
    [ -z "$id" ] && continue
    # ASCII markers only. Multi-line case branches: bash 3.2 (the
    # macOS dev shell) chokes on inline `;` separators in some
    # locales. Production is bash 5.x but the dev `bash -n` lint
    # runs on the workstation, so be defensive.
    case "$state" in
      PRIMARY)
        marker='[P]'
        color="$C_GREEN"
        ;;
      SECONDARY)
        marker='[S]'
        color="$C_BLUE"
        ;;
      STARTUP|STARTUP2|RECOVERING|ROLLBACK)
        marker='[~]'
        color="$C_YELLOW"
        ;;
      *)
        marker='[X]'
        color="$C_RED"
        ;;
    esac
    printf '  %b%s%b  %-28s  %-10s  health=%s  uptime=%ss  lag=%s' \
      "$color" "$marker" "$C_RESET" "$name" "$state" "$health" "$uptime" "$lag"
    [ -n "$hb" ] && printf '  "%s"' "$hb"
    printf '\n'
  done < <(
    printf '%s\n' "$out" \
      | sed -n 's/.*MEMBER|//p'
  )
  printf '\n'
}

cmd_export_bundle() {
  local out='' reuse_key=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --reuse-bundle-key) reuse_key=1 ;;
      -*) die "unknown export-bundle flag: $1" ;;
      *)  [ -z "$out" ] && out=$1 || die "export-bundle takes one positional <out>" ;;
    esac
    shift
  done
  [ -n "$out" ] || die "output path required: elchi-stack export-bundle <out> [--reuse-bundle-key]"

  local key=''
  if [ "$reuse_key" = "1" ]; then
    key=$(bundle::read_persisted_key) \
      || die "no persisted bundle key at /etc/elchi/.bundle-key — run on M1 of an installed cluster"
    [ -n "$key" ] || die "persisted bundle key is empty — sealed credential may be unreadable"
    log::info "reusing install-time bundle key from /etc/elchi/.bundle-key"
  else
    key=$(rand_hex 32)
  fi

  local clear=/tmp/elchi-bundle-$$.tar.gz
  # Make sure the clear tarball never lingers on a failure mid-encrypt.
  trap 'rm -f "'"$clear"'"' RETURN
  bundle::build "$clear"
  bundle::encrypt "$clear" "$out" "$key"
  rm -f "$clear"

  printf 'bundle written to %s\n' "$out"
  if [ "$reuse_key" = "1" ]; then
    printf 'decryption key: (reused from /etc/elchi/.bundle-key)\n'
  else
    printf 'decryption key: %s\n' "$key"
  fi
}

cmd_verify() {
  if [ ! -f /etc/elchi/topology.full.yaml ]; then
    die "no /etc/elchi/topology.full.yaml — install hasn't completed"
  fi
  _ssh_setup

  local total_fails=0 host
  while IFS= read -r host; do
    [ -z "$host" ] && continue
    printf '\n%s── %s ──%s\n' "$C_BOLD" "$host" "$C_RESET"

    local probe='set -e
      hn=$(hostname -s)
      fails=0

      # 1. systemd state
      while read -r unit; do
        [ -z "$unit" ] && continue
        case "$unit" in elchi-watchdog*) continue ;; esac
        if ! systemctl is-active --quiet "$unit"; then
          echo "  [FAIL] $unit not active"
          fails=$((fails+1))
        fi
      done < <(systemctl list-units --no-legend --type=service "elchi-*" | awk "{print \$1}")

      # 2. Backend registration
      if systemctl is-active --quiet elchi-controller.service 2>/dev/null; then
        if journalctl -u elchi-controller.service -n 200 --no-pager 2>/dev/null \
             | grep -qE "Controller registered.*${hn}-controller"; then
          echo "  [ OK ] controller registered as ${hn}-controller"
        else
          echo "  [WARN] controller registration log not found for ${hn}-controller"
          fails=$((fails+1))
        fi
      fi
      for u in $(systemctl list-units --no-legend --type=service "elchi-control-plane-*@*" | awk "{print \$1}"); do
        if journalctl -u "$u" -n 200 --no-pager 2>/dev/null \
             | grep -qE "Successfully registered control-plane:.*${hn}-controlplane-"; then
          echo "  [ OK ] $u registered (verified)"
        else
          echo "  [WARN] $u registration log missing"
          fails=$((fails+1))
        fi
      done

      # 3. Envoy admin /clusters → registry-cluster healthy member count
      if command -v curl >/dev/null 2>&1; then
        cluster_dump=$(curl -sf --max-time 5 http://127.0.0.1:9901/clusters?format=json 2>/dev/null || true)
        if [ -n "$cluster_dump" ]; then
          # extract registry-cluster healthy host count via jq if available
          if command -v jq >/dev/null 2>&1; then
            healthy=$(echo "$cluster_dump" | jq "[.cluster_statuses[] | select(.name==\"registry-cluster\") | .host_statuses[] | select(.health_status.eds_health_status==\"HEALTHY\")] | length" 2>/dev/null || echo 0)
            total=$(echo "$cluster_dump" | jq "[.cluster_statuses[] | select(.name==\"registry-cluster\") | .host_statuses[]] | length" 2>/dev/null || echo 0)
            echo "  [INFO] registry-cluster: ${healthy}/${total} healthy (expect 1 leader serving)"
          fi
        else
          echo "  [WARN] envoy admin :9901 unreachable"
          fails=$((fails+1))
        fi
      fi

      exit $fails
    '
    if ssh::is_local "$host"; then
      bash -c "$probe" || total_fails=$(( total_fails + $? ))
    else
      ssh::run "$host" bash -c "$probe" || total_fails=$(( total_fails + $? ))
    fi
  done < /etc/elchi/nodes.list

  printf '\n'
  if [ "$total_fails" = "0" ]; then
    log::ok "cluster verify: all checks passed"
  else
    log::err "cluster verify: ${total_fails} issue(s) found"
    return 1
  fi
}

cmd_show_secret() {
  local name=${1:-}
  local sec_file=/etc/elchi/secrets.env
  if [ ! -r "$sec_file" ]; then
    die "cannot read ${sec_file} (must run as root on M1)"
  fi

  # Read a single key=value, returning just the value.
  _read() { grep -E "^${1}=" "$sec_file" | tail -n1 | cut -d= -f2-; }

  case "$name" in
    grafana)
      printf 'username: %s\npassword: %s\n' \
        "$(_read ELCHI_GRAFANA_USER)" "$(_read ELCHI_GRAFANA_PASSWORD)"
      ;;
    jwt)        _read ELCHI_JWT_SECRET; printf '\n' ;;
    gslb)       _read ELCHI_GSLB_SECRET; printf '\n' ;;
    mongo-app)
      printf 'username: %s\npassword: %s\n' \
        "$(_read ELCHI_MONGO_USERNAME)" "$(_read ELCHI_MONGO_PASSWORD)"
      ;;
    mongo-root)
      printf 'username: %s\npassword: %s\n' \
        "$(_read ELCHI_MONGO_ROOT_USERNAME)" "$(_read ELCHI_MONGO_ROOT_PASSWORD)"
      ;;
    all)
      printf '%sCredentials at %s (mode 0640 root:elchi)%s\n\n' \
        "$C_BOLD" "$sec_file" "$C_RESET"
      printf '  %sGrafana admin:%s   %s / %s\n' "$C_CYAN" "$C_RESET" \
        "$(_read ELCHI_GRAFANA_USER)" "$(_read ELCHI_GRAFANA_PASSWORD)"
      printf '  %sJWT secret:%s      %s\n' "$C_CYAN" "$C_RESET" \
        "$(_read ELCHI_JWT_SECRET)"
      printf '  %sGSLB secret:%s     %s\n' "$C_CYAN" "$C_RESET" \
        "$(_read ELCHI_GSLB_SECRET)"
      printf '  %sMongo app user:%s  %s / %s\n' "$C_CYAN" "$C_RESET" \
        "$(_read ELCHI_MONGO_USERNAME)" "$(_read ELCHI_MONGO_PASSWORD)"
      printf '  %sMongo root:%s      %s / %s\n' "$C_CYAN" "$C_RESET" \
        "$(_read ELCHI_MONGO_ROOT_USERNAME)" "$(_read ELCHI_MONGO_ROOT_PASSWORD)"
      ;;
    "")
      die "secret name required (one of: grafana, jwt, gslb, mongo-app, mongo-root, all)"
      ;;
    *)
      die "unknown secret: $name (use grafana | jwt | gslb | mongo-app | mongo-root | all)"
      ;;
  esac
}

cmd_rotate_secret() {
  local name=${1:?secret name required (one of: jwt, gslb, grafana)}

  # Grafana is a special case: the new password must also be pushed
  # into the live grafana DB via grafana-cli, and the rotation only
  # affects M1 (Grafana is singleton). Handle it before the cluster-
  # wide JWT/GSLB path so we don't touch every node.
  if [ "$name" = "grafana" ]; then
    local new_pwd
    new_pwd="elchi-$(rand_hex 6)"
    grafana::rotate_admin_password "$new_pwd"
    log::info "new grafana admin password: ${new_pwd}"
    log::info "  retrieve later via: elchi-stack show-secret grafana"
    return 0
  fi

  local key var
  case "$name" in
    jwt)  var=ELCHI_JWT_SECRET;  key=$(rand_hex 32) ;;
    gslb) var=ELCHI_GSLB_SECRET; key=$(rand_alnum 48) ;;
    *) die "unknown secret: $name (use jwt|gslb|grafana)" ;;
  esac

  log::info "rotating ${var}"
  sed -i "s|^${var}=.*|${var}=${key}|" /etc/elchi/secrets.env

  # The secret is also baked into every variant's common.env (which is
  # what the systemd units actually source). secrets.env is the source of
  # truth, but rotation has to also re-render the per-variant common.env
  # files and push them to every node — otherwise the restart picks up
  # the OLD value and the rotation is silently a no-op.
  log::info "re-rendering per-variant common.env on M1"
  backend::render_per_version_configs

  # SSH driver — credentials come from persisted /etc/elchi/orchestrator.env
  # via _ssh_setup, so this works without operator flags.
  _ssh_setup

  # Walk every variant and ship its newly-rendered common.env to every
  # remote node. Local node is already updated by render_per_version_configs.
  local -a variants
  mapfile -t variants < <(
    awk '/^  backend_variants:/{f=1; next} f && /^    -/{print $2}
         f && /^[a-zA-Z]/{exit}' /etc/elchi/topology.full.yaml
  )

  local host v
  while IFS= read -r host; do
    [ -z "$host" ] && continue
    if ssh::is_local "$host"; then
      # M1: secrets.env + every variant's common.env are already on disk.
      # Restart everything that consumes them.
      systemctl restart 'elchi-controller.service' 'elchi-control-plane-*@*.service' 'elchi-registry.service' 2>/dev/null || true
    else
      # M2/M3: ship secrets.env (for completeness/future tooling) + every
      # variant's common.env, then restart. ssh::scp streams via
      # `sudo install /dev/stdin` so we write straight to the final
      # destination — no /tmp staging that systemd-tmpfiles or a
      # reboot could evict between two SSH calls.
      ssh::scp /etc/elchi/secrets.env "$host" /etc/elchi/secrets.env
      for v in "${variants[@]}"; do
        ssh::scp "/etc/elchi/${v}/common.env" "$host" "/etc/elchi/${v}/common.env"
      done
      # Fix up ownership (install lands files root:root) and restart.
      local remote_cmd="chown root:elchi /etc/elchi/secrets.env && chmod 0640 /etc/elchi/secrets.env"
      for v in "${variants[@]}"; do
        remote_cmd+=" && chown root:elchi /etc/elchi/${v}/common.env && chmod 0640 /etc/elchi/${v}/common.env"
      done
      remote_cmd+=' && systemctl restart "elchi-controller.service" "elchi-control-plane-*@*.service"'
      ssh::run_sudo "$host" "$remote_cmd"
    fi
  done < /etc/elchi/nodes.list
  log::ok "${var} rotated and propagated"
}

# ----- dispatch ----------------------------------------------------------
case "${1:-}" in
  status)            shift; cmd_status "$@" ;;
  logs)              shift; cmd_logs "$@" ;;
  reload-envoy)      shift; cmd_reload_envoy "$@" ;;
  add-node)          shift; cmd_add_node "$@" ;;
  init-replica-set)  shift; cmd_init_rs "$@" ;;
  mongo-status)      shift; cmd_mongo_status "$@" ;;
  export-bundle)     shift; cmd_export_bundle "$@" ;;
  show-secret)       shift; cmd_show_secret "$@" ;;
  rotate-secret)     shift; cmd_rotate_secret "$@" ;;
  verify)            shift; cmd_verify "$@" ;;
  -h|--help|"")      usage ;;
  *) printf 'unknown subcommand: %s\n\n' "$1" >&2; usage; exit 2 ;;
esac
