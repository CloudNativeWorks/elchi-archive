# versions.env — SINGLE SOURCE OF TRUTH for the elchi Docker Swarm stack
# image tags. Parallels deploy/standalone/lib/versions.sh, but pins
# CONTAINER IMAGE tags instead of release-asset versions.
#
# ┌──────────────────────────────────────────────────────────────────┐
# │  EDIT THIS FILE to change which image tag each component uses.    │
# └──────────────────────────────────────────────────────────────────┘
#
# install.sh sources this once at startup. Every value below is a default
# fallback: an explicit environment variable or CLI flag
# (--backend-version=, --ui-version=, --coredns-version=,
# --collector-version=) STILL overrides whatever is pinned here.
#
# The elchi-specific images live on Docker Hub under `jhonbrownn/*`
# (the same images the Helm chart consumes). Third-party services use
# their official upstream images.

# --- elchi component images (Docker Hub: jhonbrownn/*) ---------------------

# elchi-backend — one or more full variant tags, comma-separated. Each tag
# matches a `jhonbrownn/elchi-backend:<tag>` image AND the standalone
# backend-variant naming scheme (vX.Y.Z-vA.B.C-envoyP.Q.R). The same image
# runs all three backend roles (registry / controller / control-plane) via
# subcommand. One control-plane service + one Envoy cluster is generated
# per variant; the embedded envoy version must be UNIQUE across variants.
ELCHI_DEFAULT_BACKEND_VARIANTS="v1.6.5-v0.14.0-envoy1.38.3"

# elchi UI (nginx-served SPA). jhonbrownn/elchi:<tag>.
ELCHI_DEFAULT_UI_VERSION="v1.5.3"

# CoreDNS build carrying the elchi GSLB plugin. jhonbrownn/elchi-coredns:<tag>.
ELCHI_DEFAULT_COREDNS_VERSION="v0.1.4"

# elchi-collector — Envoy ALS ingestion. jhonbrownn/elchi-collector:<tag>.
ELCHI_DEFAULT_COLLECTOR_VERSION="v0.1.11"

# Docker Hub namespace for the elchi-specific images. Override with
# ELCHI_IMAGE_REGISTRY=<registry>/<namespace> to point at a private mirror
# (e.g. a local registry:2 used for air-gapped multi-node distribution).
ELCHI_DEFAULT_IMAGE_REPO="jhonbrownn"

# --- third-party images (official upstreams) -------------------------------
# Pinned tags so `save-images.sh` produces a reproducible offline bundle.
ELCHI_DEFAULT_ENVOY_IMAGE="envoyproxy/envoy:v1.37.0"
ELCHI_DEFAULT_MONGO_IMAGE="mongo:8.0"
ELCHI_DEFAULT_CLICKHOUSE_IMAGE="clickhouse/clickhouse-server:24.8"
ELCHI_DEFAULT_GRAFANA_IMAGE="grafana/grafana:11.6.0"
ELCHI_DEFAULT_VM_IMAGE="victoriametrics/victoria-metrics:v1.93.5"
ELCHI_DEFAULT_OTEL_IMAGE="otel/opentelemetry-collector-contrib:0.89.0"
